# Transitional env template for local-only secrets.
# Source-specific non-secret examples live in config/sources/*.example.toml.
# Copy only the needed provider block into .local/secrets/<provider>.env.

# Dexcom Clarity / Stelo local pull settings.
# Copy to .local/secrets/dexcom_clarity.env and fill local-only values.

DEXCOM_CLARITY_USERNAME=
DEXCOM_CLARITY_PASSWORD=

# Optional but avoids discovery ambiguity if Clarity returns multiple accounts.
DEXCOM_CLARITY_SUBJECT_ID=

# Optional; the script can usually fetch these from Clarity once authenticated.
DEXCOM_CLARITY_FIRST_NAME=
DEXCOM_CLARITY_LAST_NAME=
DEXCOM_CLARITY_DATE_OF_BIRTH=

DEXCOM_CLARITY_LOCALE=en-US
DEXCOM_CLARITY_UNITS=mgdl
DEXCOM_CLARITY_API_BASE=https://clarity.dexcom.com/api
DEXCOM_CLARITY_TIMEZONE=America/Los_Angeles

# Optional escape hatch if Dexcom changes interactive auth:
# DEXCOM_CLARITY_SUBJECT_TOKEN=

# Fitbit Web API local pull settings. Copy Fitbit-specific values to
# .local/secrets/fitbit.env.
FITBIT_CLIENT_ID=your_fitbit_client_id
FITBIT_CLIENT_TYPE=server
FITBIT_CLIENT_SECRET=
FITBIT_REDIRECT_URI=http://localhost:8000/auth/fitbit/callback
FITBIT_TAKEOUT_ROOT=~/Documents/health/sources/fitbit_takeout/export=YYYY-MM-DD

# Polar AccessLink local pull settings. Copy Polar-specific values to
# .local/secrets/polar.env.
POLAR_CLIENT_ID=
POLAR_CLIENT_SECRET=
POLAR_REDIRECT_URI=http://localhost:8001/auth/polar/callback

# Nike Run Club. The bearer token is short-lived, so the nike-run-club skill
# takes a fresh one per run via --bearer-token-stdin (pasted from a logged-in
# nike.com request) and never reads it from the environment.
NIKE_RUN_CLUB_TIMEZONE=America/Los_Angeles
# Optional non-secret override for the raw export folder date.
# NIKE_RUN_CLUB_EXPORT_DATE=YYYY-MM-DD

# Genetics source resolution (read from the environment by scripts/genetics/*).
# HEALTH_SOURCES_DIR: root of original source dumps (default ~/Documents/health/sources).
# HEALTH_GENOME_FILE: the 23andMe raw export. Absolute path, or a filename
#   relative to <sources>/genetics/23andme/. If unset, the newest
#   export=*/genome*.txt under that dir is auto-discovered. Kept out of code so
#   the export filename (which embeds the account name) is never committed.
# HEALTH_SOURCES_DIR=
# HEALTH_GENOME_FILE=
# HEALTH_SNP_ANNOTATIONS=
